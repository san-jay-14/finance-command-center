# Copy to evals/.env (gitignored) and fill in. Real environment variables
# take precedence over this file.

# Your Supabase project URL, e.g. https://abcd1234.supabase.co
SUPABASE_URL=

# Service-role key (server-side only). The runner uses it to write eval_* rows;
# it bypasses RLS. Never ship this to the frontend.
SUPABASE_SERVICE_ROLE_KEY=

# Shared secret gating handle-message's dry_run path. Must exactly match the
# EVAL_SHARED_SECRET set as a Supabase project secret on the function.
EVAL_SHARED_SECRET=

# Anthropic API key — used ONLY by the grader (evals:grade) for the
# Claude-as-judge layer. The runner does not need this. Never ship to the
# frontend.
ANTHROPIC_API_KEY=
